# ──────────────────────────────────────────────
# Vessify Backend — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# Server
NODE_ENV=development
PORT=3001

# PostgreSQL Database
DATABASE_URL="postgresql+asyncpg://neondb_owner:npg_nl8WPyAp0OVv@ep-orange-bread-a5x2mlow-pooler.us-east-2.aws.neon.tech/neondb?ssl=require"

# Better Auth
BETTER_AUTH_SECRET="your-super-secret-key-at-least-32-chars-long-here"
BETTER_AUTH_URL="http://localhost:3001"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
